# Shared API key for client auth (sk-xxx format)
API_KEY=sk-your-key-here

# Deepgram API key (used to access ElevenLabs TTS via Agent API)
DEEPGRAM_API_KEY=your-deepgram-api-key

# Server port
PORT=3100

# WebSocket timeout for TTS synthesis (ms)
WS_TIMEOUT_MS=3000000

# Max input text length (characters)
MAX_INPUT_LENGTH=162555
